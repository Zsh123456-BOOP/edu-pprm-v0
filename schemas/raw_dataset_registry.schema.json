{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Edu-PPRM Raw Dataset Registry",
  "type": "object",
  "required": ["sources", "guards"],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_name",
          "url_or_path",
          "license",
          "task_use",
          "allowed_split",
          "release_flag"
        ],
        "properties": {
          "source_name": {"type": "string"},
          "url_or_path": {"type": "string"},
          "license": {"type": "string"},
          "role": {"type": "string"},
          "task_use": {"type": "array", "items": {"type": "string"}},
          "allowed_split": {"type": "array", "items": {"type": "string"}},
          "release_flag": {"type": "string"},
          "default_loader": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "guards": {
      "type": "object",
      "properties": {
        "external_eval_only_must_not_train": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reserved_fields_must_remain_optional": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
